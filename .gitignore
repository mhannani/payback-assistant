# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage

# Environment / secrets
.env
.env.*
!.env.example
!.env.prod.example

# IDE / OS
.idea/
.vscode/
.DS_Store

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl IS committed (pins provider hashes for reproducible plans).

# Frontend (Next.js) build + dependency artifacts. These live under apps/frontend/ (the showcase
# branch). Ignore them from the repo root so any branch — including main, which has no
# apps/frontend/.gitignore — never sees thousands of untracked build files.
apps/frontend/node_modules/
apps/frontend/.next/
apps/frontend/out/
apps/frontend/next-env.d.ts
apps/frontend/.npmrc
