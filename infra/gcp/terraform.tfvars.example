# Copy to terraform.tfvars (gitignored) and fill in. Never commit real secrets.
project_id = "your-gcp-project"
region     = "europe-west3"
image      = "europe-west3-docker.pkg.dev/your-gcp-project/payback/api:latest"

# The DB password is generated by Terraform — you don't set it.
# The default all-Vertex path needs NO key (the Cloud Run service account authenticates via ADC),
# so leave llm_api_key unset. Only set it (+ an llm_model like openai/… or anthropic/…) to use a
# keyed provider instead — prefer the environment (TF_VAR_llm_api_key) over this file.
# llm_api_key = "sk-..."
