# Copy to terraform.tfvars (gitignored) and fill in. Never commit real secrets.
region     = "eu-central-1"
vpc_id     = "vpc-xxxxxxxx"
subnet_ids = ["subnet-aaaa", "subnet-bbbb"] # ≥2 in different AZs
# image defaults to the public GHCR image; override for an all-AWS supply chain (ECR ref).
# The DB password is generated by Terraform — you don't set it.

# The agent's model (LiteLLM id). Defaults to openai/gpt-4o-mini. Switch providers here — the key's
# env var name (OPENAI_API_KEY / ANTHROPIC_API_KEY / GEMINI_API_KEY) is derived from the prefix, so
# you never set it yourself; just change the model and pass the matching key below.
#   llm_model = "anthropic/claude-3-5-sonnet-latest"   # → key injected as ANTHROPIC_API_KEY
# llm_model = "openai/gpt-4o-mini"

# The only secret: the key for whatever provider llm_model points at. Prefer the environment
# (TF_VAR_llm_api_key) over this file.
llm_api_key = "sk-..."
