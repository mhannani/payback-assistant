# Copy to terraform.tfvars (gitignored) and fill in. Never commit real secrets.
region     = "eu-central-1"
image      = "<account>.dkr.ecr.eu-central-1.amazonaws.com/payback-api:latest"
vpc_id     = "vpc-xxxxxxxx"
subnet_ids = ["subnet-aaaa", "subnet-bbbb"] # ≥2 in different AZs

# Secrets — prefer environment variables (TF_VAR_db_password / TF_VAR_openai_api_key) over a file.
db_password    = "change-me"
openai_api_key = "sk-..."
