# Production configuration template — cloud-first (no local model / torch).
#
# In a real deploy these are NOT read from a file: the Terraform modules inject them as container
# environment variables, and secrets come from the cloud secret store (Secret Manager / Secrets
# Manager), never from a committed file. This template documents the intended prod settings.

# Serve embeddings off-host. The production image has no local embedder, so this must be a cloud
# provider. GCP → vertex; AWS → openai.
EMBEDDING_PROVIDER=vertex          # vertex (GCP) | openai (AWS)

# Agent LLM (LiteLLM model id). Match it to the cloud:
#   GCP → vertex_ai/gemini-2.0-flash   AWS → openai/gpt-4o-mini
LLM_MODEL=vertex_ai/gemini-2.0-flash

# Vertex (GCP) — uses Application Default Credentials, not a key.
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=europe-west3
VERTEX_MODEL=text-multilingual-embedding-002

# OpenAI (AWS, or openai/* models) — injected from the secret store in cloud, not committed here.
OPENAI_API_KEY=

# Database — injected by Terraform from the managed Postgres instance (Cloud SQL / RDS).
DATABASE_URL=postgresql+asyncpg://payback:PASSWORD@HOST:5432/payback
