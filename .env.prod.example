# Production configuration template — cloud-first (no local model / torch).
#
# In a real deploy these are NOT read from a file: the Terraform modules inject them as container
# environment variables, and secrets come from the cloud secret store (Secret Manager / Secrets
# Manager), never from a committed file. This template documents the intended prod settings.

# Serve embeddings off-host. The production image has no local embedder, so this must be a cloud
# provider. GCP → vertex; AWS → openai.
EMBEDDING_PROVIDER=vertex          # vertex (GCP) | openai (AWS)

# Agent LLM (LiteLLM model id). Match it to the cloud:
#   GCP → vertex_ai/gemini-2.5-flash   AWS → openai/gpt-4o-mini
LLM_MODEL=vertex_ai/gemini-2.5-flash

# Vertex (GCP) — uses Application Default Credentials, not a key. One project/region pair serves both
# the embedder and the LLM (LiteLLM reads these exact names). gemini-2.5-flash 404s in europe-west3,
# so us-central1 is the safe region even if your data lives elsewhere.
VERTEXAI_PROJECT=your-gcp-project
VERTEXAI_LOCATION=us-central1
VERTEX_MODEL=text-multilingual-embedding-002

# OpenAI (AWS, or openai/* models) — injected from the secret store in cloud, not committed here.
OPENAI_API_KEY=

# Database — injected by Terraform from the managed Postgres instance (Cloud SQL / RDS).
DATABASE_URL=postgresql+asyncpg://payback:PASSWORD@HOST:5432/payback

# Voice dictation (Deepgram) — powers the widget mic. Key stays server-side. Empty = voice off.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# Web widget origins allowed to call the API (the widget is served from a different host).
CORS_ORIGINS=https://payback.mhannani.me,http://localhost:3000

# ── Observability (Langfuse v3, self-hosted) ────────────────────────
# One env file feeds BOTH sides: observability/docker-compose.langfuse.yml provisions the instance with these
# exact keys (LANGFUSE_INIT_*), and the API's tracing (app/llm/tracing.py) sends with them — so
# they can't drift. Dashboard: https://langfuse.payback.mhannani.me (DNS A record → this host).
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-payback-prod          # generate real values for prod
LANGFUSE_SECRET_KEY=sk-lf-CHANGE-ME
LANGFUSE_OTEL_HOST=http://payback_langfuse:3000 # in-network via the shared traefik network
LANGFUSE_PUBLIC_URL=https://langfuse.payback.mhannani.me
# Instance secrets (compose substitutes these; never commit real values):
LANGFUSE_DB_PASSWORD=CHANGE-ME
LANGFUSE_REDIS_PASSWORD=CHANGE-ME
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGE-ME
LANGFUSE_MINIO_PASSWORD=CHANGE-ME
LANGFUSE_SALT=CHANGE-ME-64-hex                  # openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=CHANGE-ME-64-hex        # openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=CHANGE-ME
LANGFUSE_ADMIN_EMAIL=admin@payback.local
LANGFUSE_ADMIN_PASSWORD=CHANGE-ME
