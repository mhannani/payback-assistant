# syntax=docker/dockerfile:1
# Development image: includes dev dependencies (pytest, ruff) and the test
# suite so the whole workflow — run, seed, test, lint — happens inside the
# container. The lean production image is the separate multi-stage Dockerfile.

FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

# Cache the embedding model inside the image so seeding/serving never download it
# at runtime (the local embedder is the default and must work offline).
ENV HF_HOME=/opt/hf-cache \
    EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Install all dependencies (including dev) first — cached unless the lock changes.
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project

# Bake the embedding model into the image (downloaded once, into HF_HOME above).
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('$EMBEDDING_MODEL_NAME')"

# After the model is cached, force offline so no code path reaches the network for it.
ENV HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1

# Copy the whole backend (app + data + tests) for an interactive dev container.
COPY . /app/

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
