# Example configuration. Copy to .env.dev (dev) / .env.prod (prod) and adjust.
# Real .env* files are git-ignored; only this example is committed.
# Every value below is read by app/config.py:Settings. Real environment variables
# (e.g. set by docker-compose or the shell) override the file.

# ── App ─────────────────────────────────────────────────────────────
# Free-text environment label, surfaced for diagnostics only.
#   values: development | staging | production (any string accepted)
APP_ENV=development

# ── Database (Postgres + pgvector) ──────────────────────────────────
POSTGRES_HOST=db          # hostname of the Postgres server ('db' = the compose service)
POSTGRES_PORT=5432        # Postgres port INSIDE the container network (host maps to 5433)
POSTGRES_DB=payback       # database name
POSTGRES_USER=payback     # database user
POSTGRES_PASSWORD=payback # database password (use a secret in production)

# ── Embeddings: a managed provider turns text into vectors ──────────
# A cloud call, so a key/credentials are required.
#   values: openai | vertex
# The vector dimension is derived from the provider + model (no separate setting); init_db sizes
# the schema to it (OpenAI text-embedding-3-small = 1536 · Vertex multilingual-002 = 768).
EMBEDDING_PROVIDER=openai
# OpenAI settings — read when EMBEDDING_PROVIDER=openai (also serves the agent LLM).
OPENAI_API_KEY=
OPENAI_MODEL=text-embedding-3-small               # OpenAI embedding model (1536-dim)
# Vertex AI settings — read when EMBEDDING_PROVIDER=vertex (uses ADC, not an API key).
VERTEX_PROJECT=                                   # GCP project id (e.g. my-gcp-project)
VERTEX_LOCATION=europe-west3                      # GCP region
VERTEX_MODEL=text-multilingual-embedding-002      # Vertex embedding model id (768-dim)

# ── Retrieval: where vectors live + how results are filtered & ranked ─
# Vector store backend.
#   values: pgvector   (only backend implemented today)
RETRIEVER_BACKEND=pgvector
# Vector noise cutoff — drops irrelevant candidates before fusion.
#   absolute : keep distance <= a tuned ceiling (default; most robust)
#   autocut  : cut at the largest distance gap (Weaviate-style, parameter-free)
#   relative : keep within a band of the best match (kept to show its failure mode)
#   none     : no cutoff (baseline; lets noise through)
FILTER_STRATEGY=absolute
# Final ordering strategy.
#   constrained : relevance-first + per-partner cap + guardrail (default)
#   mmr         : Maximal Marginal Relevance (diversity vs relevance trade-off)
#   zscore      : z-score standardized relevance (parametric alternative)
RANKING_STRATEGY=constrained

# ── Intent agent LLM (reached via a LiteLLM gateway) ────────────────
# The agent classifies a query with an LLM. LLM_MODEL is a LiteLLM model id of the
# form '<provider>/<model>'. LiteLLM reads the matching provider credential from the
# environment, so switching provider = change LLM_MODEL + set that provider's key below.
#   examples: openai/gpt-4o-mini · vertex_ai/gemini-2.0-flash · anthropic/claude-3-5-haiku-latest
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.0                # classification is deterministic; leave at 0

# Provider credentials for the agent LLM — fill in the one matching LLM_MODEL (LiteLLM reads
# these from the environment by name). OPENAI_API_KEY is the one declared above (it serves both
# openai/* models and the OpenAI embedder). Add the others only if you point LLM_MODEL at them.
# Keys go on their own clean lines (no trailing `# comment`, which leaks into the value).
# ANTHROPIC_API_KEY=   for LLM_MODEL=anthropic/*  (sk-ant-...)
# GEMINI_API_KEY=      for LLM_MODEL=gemini/*      (AI Studio key, not Vertex)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# For LLM_MODEL=vertex_ai/* the gateway uses GCP Application Default Credentials + the
# VERTEX_PROJECT / VERTEX_LOCATION set above (no API key).

# ── Voice dictation (Deepgram streaming STT) ────────────────────────
# Powers the widget mic: the /voice/dictate-stream WebSocket proxies browser audio to Deepgram
# and streams transcripts back. The key stays server-side. Leave empty to run without voice — the
# mic just closes with a "not configured" message; everything else works.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3                              # Deepgram model for dictation

# ── Web widget (CORS) ───────────────────────────────────────────────
# Browser origins allowed to call the API (the embeddable widget is served from a different
# origin). Comma-separated. Defaults cover prod + local Next dev if unset.
# CORS_ORIGINS=https://payback.mhannani.me,http://localhost:3000
